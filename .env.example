# Copy to .env.local and fill in real values. Do not commit .env or .env.local.

# SMTP2Go – required for group emails (dashboard + Firebase sendGroupEmail)
SMTP2GO_API_KEY=your-smtp2go-api-key
SMTP2GO_SENDER_EMAIL=result@roamjet.net
SMTP2GO_SENDER_NAME=Vitrix App

# Optional: Firebase (for local server / API routes that use Firebase Admin)
# FIREBASE_PROJECT_ID=muscule-up
# FIREBASE_CLIENT_EMAIL=...
# FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"
